          <view class="matrix-item">
            <text class="matrix-num">210款</text>
            <text class="matrix-name">功能性食品</text>
            <text class="matrix-channel">OTC渠道</text>
          </view>
          <view class="matrix-item">
            <text class="matrix-num">168款</text>
            <text class="matrix-name">消字号产品</text>
            <text class="matrix-channel">院线渠道</text>
          </view>
          <view class="matrix-item">
            <text class="matrix-num">132款</text>
            <text class="matrix-name">妆字号产品</text>
            <text class="matrix-channel">CS渠道</text>
