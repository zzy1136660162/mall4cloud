<view class="container">
  <!-- 顶部Banner -->
  <view class="banner">
    <view class="banner-content">
      <text class="banner-title">共创医健产业创新生态圈</text>
      <text class="banner-subtitle">大道至简 · 实干为要</text>
    </view>
  </view>

  <!-- 核心数据展示 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-num">13</text>
      <text class="stat-unit">年</text>
      <text class="stat-label">行业深耕</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">3万+</text>
      <text class="stat-label">服务企业</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">1000+</text>
      <text class="stat-label">精选产品</text>
    </view>
  </view>

  <!-- 三个切换按钮 -->
  <view class="tab-section">
    <view class="tab-wrapper">
      <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
        <view class="tab-icon">🏆</view>
        <text class="tab-text">杰东认证</text>
        <view class="tab-line" wx:if="{{currentTab === 0}}"></view>
      </view>
      <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
        <view class="tab-icon">🏭</view>
        <text class="tab-text">杰东生产</text>
        <view class="tab-line" wx:if="{{currentTab === 1}}"></view>
      </view>
      <view class="tab-item {{currentTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">
        <view class="tab-icon">🚀</view>
        <text class="tab-text">杰东营销</text>
        <view class="tab-line" wx:if="{{currentTab === 2}}"></view>
      </view>
    </view>
  </view>

  <!-- 内容区域 -->
  <scroll-view class="content-area" scroll-y="true">
    <!-- 认证板块 -->
    <view class="content-panel" wx:if="{{currentTab === 0}}">
      <view class="panel-header">
        <view class="panel-title">破解产品全生命周期中的复杂课题</view>
        <view class="panel-subtitle">打造全球大健康产业合规智造领航者</view>
      </view>

      <!-- 认证类别卡片 -->
      <view class="card-grid">
        <view class="cert-card">
          <view class="cert-icon" style="background: linear-gradient(135deg, #134585, #1a5aa0);">🏥</view>
          <text class="cert-name">医疗器械</text>
          <text class="cert-desc">一类/二类/三类注册</text>
        </view>
        <view class="cert-card">
          <view class="cert-icon" style="background: linear-gradient(135deg, #134585, #1a5aa0);">💄</view>
          <text class="cert-name">化妆品</text>
          <text class="cert-desc">普通/特殊化妆品</text>
        </view>
        <view class="cert-card">
          <view class="cert-icon" style="background: linear-gradient(135deg, #134585, #1a5aa0);">🧴</view>
          <text class="cert-name">消毒用品</text>
          <text class="cert-desc">消字号产品备案</text>
        </view>
        <view class="cert-card">
          <view class="cert-icon" style="background: linear-gradient(135deg, #134585, #1a5aa0);">🌿</view>
          <text class="cert-name">保健用品</text>
          <text class="cert-desc">吉林保健用品批件</text>
        </view>
        <view class="cert-card">
          <view class="cert-icon" style="background: linear-gradient(135deg, #134585, #1a5aa0);">🍵</view>
          <text class="cert-name">功能性食品</text>
          <text class="cert-desc">食字号/特膳/特医</text>
        </view>
        <view class="cert-card">
          <view class="cert-icon" style="background: linear-gradient(135deg, #134585, #1a5aa0);">⚕️</view>
          <text class="cert-name">院内制剂</text>
          <text class="cert-desc">医疗机构制剂备案</text>
        </view>
      </view>

      <!-- 服务优势 -->
      <view class="advantage-section">
        <view class="section-title">服务优势</view>
        <view class="advantage-list">
          <view class="advantage-item">
            <view class="advantage-dot"></view>
            <text class="advantage-text">主力团队 40+ 人，交付团队 100 人</text>
          </view>
          <view class="advantage-item">
            <view class="advantage-dot"></view>
            <text class="advantage-text">深耕大健康产业 13 年</text>
          </view>
          <view class="advantage-item">
            <view class="advantage-dot"></view>
            <text class="advantage-text">成功服务 3万+ 企业</text>
          </view>
          <view class="advantage-item">
            <view class="advantage-dot"></view>
            <text class="advantage-text">精准货盘矩阵 1075 个 SKU</text>
          </view>
        </view>
      </view>

      <!-- CTA按钮 -->
      <view class="cta-section">
        <button class="cta-btn primary">立即咨询认证</button>
      </view>
    </view>

    <!-- 生产板块 -->
    <view class="content-panel" wx:if="{{currentTab === 1}}">
      <view class="panel-header">
        <view class="panel-title">OEM/ODM 贴牌加工</view>
        <view class="panel-subtitle">从产品设计、研发到量产的全链条解决方案</view>
      </view>

      <!-- 剂型类型 -->
      <view class="section-block">
        <view class="section-title">剂型类型</view>
        <view class="dosage-tags">
          <view class="dosage-tag">膏剂</view>
          <view class="dosage-tag">粉剂</view>
          <view class="dosage-tag">片剂</view>
          <view class="dosage-tag">液体</view>
          <view class="dosage-tag">颗粒</view>
          <view class="dosage-tag">凝胶</view>
        </view>
      </view>

      <!-- 产品类别 -->
      <view class="section-block">
        <view class="section-title">产品类别</view>
        <view class="category-grid">
          <view class="category-item">
            <text class="category-name">纤体瘦身贴</text>
            <text class="category-tag">辅助减肥</text>
          </view>
          <view class="category-item">
            <text class="category-name">疏通活络液</text>
            <text class="category-tag">缓解疼痛</text>
