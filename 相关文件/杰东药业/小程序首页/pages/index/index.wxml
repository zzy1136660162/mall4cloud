          <view class="product-item">
            <view class="product-info">
              <text class="product-name">屁屁黄金</text>
              <text class="product-desc">减少红肿、滋润保湿</text>
            </view>
            <view class="product-arrow">›</view>
          </view>
          <view class="product-item">
            <view class="product-info">
              <text class="product-name">舒痛通络贴</text>
              <text class="product-desc">消炎镇痛，适用于肩颈腰腿</text>
            </view>
            <view class="product-arrow">›</view>
          </view>
          <view class="product-item">
            <view class="product-info">
              <text class="product-name">男性抑菌喷剂</text>
              <text class="product-desc">对多种细菌、真菌有抑制作用</text>
            </view>
            <view class="product-arrow">›</view>
          </view>
        </view>
