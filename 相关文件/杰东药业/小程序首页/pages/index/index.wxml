            <text class="resource-desc">快速响应配方需求</text>
          </view>
        </view>
      </view>

      <!-- 货盘矩阵 -->
      <view class="section-block">
        <view class="section-title">货盘矩阵</view>
        <view class="product-matrix">
          <view class="matrix-item">
            <text class="matrix-num">45款</text>
            <text class="matrix-name">医疗器械</text>
            <text class="matrix-channel">电商渠道</text>
