          <view class="category-item">
            <text class="category-name">舒缓通鼻膏</text>
            <text class="category-tag">改善鼻部</text>
          </view>
          <view class="category-item">
            <text class="category-name">净肤康乳膏</text>
            <text class="category-tag">改善皮肤</text>
          </view>
        </view>
      </view>

      <!-- 保健用品功效 -->
      <view class="section-block">
        <view class="section-title">保健用品功效覆盖（15大类）</view>
        <view class="function-tags">
          <view class="function-tag">鼻部护理</view>
          <view class="function-tag">狐臭产品</view>
          <view class="function-tag">美肤护肤</view>
          <view class="function-tag">调理亚健康</view>
          <view class="function-tag">护目</view>
          <view class="function-tag">面瘫康复</view>
          <view class="function-tag">固肾养肾</view>
          <view class="function-tag">缓解疼痛</view>
