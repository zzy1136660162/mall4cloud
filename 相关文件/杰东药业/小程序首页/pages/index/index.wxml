        <view class="advantage-list">
          <view class="advantage-item">
            <view class="advantage-dot"></view>
            <text class="advantage-text">安评评价全套手续类目 200+</text>
          </view>
          <view class="advantage-item">
            <view class="advantage-dot"></view>
            <text class="advantage-text">满足市场 95% 产品贴牌需求</text>
          </view>
          <view class="advantage-item">
            <view class="advantage-dot"></view>
            <text class="advantage-text">涵盖贴剂、粉剂、颗粒、液体、膏剂等多种剂型</text>
          </view>
        </view>
      </view>

      <!-- CTA按钮 -->
      <view class="cta-section">
        <button class="cta-btn primary">获取贴牌方案</button>
      </view>
    </view>

    <!-- 营销板块 -->
    <view class="content-panel" wx:if="{{currentTab === 2}}">
      <view class="panel-header">
        <view class="panel-title">垂直供应链智能中台</view>
        <view class="panel-subtitle">重构产业价值链，打造产业级供应链协同平台</view>
      </view>

      <!-- 核心模式 -->
      <view class="section-block">
        <view class="section-title">核心模式</view>
        <view class="model-cards">
          <view class="model-card">
            <view class="model-icon">📦</view>
            <text class="model-name">上游·深度整合</text>
            <text class="model-desc">直连源头，构建数字化、柔性化供应池</text>
          </view>
          <view class="model-card">
            <view class="model-icon">⚙️</view>
            <text class="model-name">中台·智能枢纽</text>
            <text class="model-desc">沉淀核心能力，一站式赋能上下游</text>
          </view>
          <view class="model-card">
            <view class="model-icon">🌐</view>
            <text class="model-name">下游·无限裂变</text>
            <text class="model-desc">独创无限合伙人生态体系</text>
          </view>
        </view>
      </view>

      <!-- 资源优势 -->
      <view class="section-block">
        <view class="section-title">资源优势</view>
        <view class="resource-cards">
