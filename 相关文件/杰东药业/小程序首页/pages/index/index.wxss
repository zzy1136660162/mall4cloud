/* 主色调: #134585 */

.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 120rpx;
}

/* 顶部Banner */
.banner {
  background: linear-gradient(135deg, #134585 0%, #1a5aa0 50%, #134585 100%);
  padding: 60rpx 40rpx;
  text-align: center;
}

.banner-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 8rpx;
}

/* 核心数据展示 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: #ffffff;
  padding: 30rpx 20rpx;
  margin: -30rpx 30rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(19, 69, 133, 0.1);
  position: relative;
  z-index: 10;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #134585;
}

.stat-unit {
  font-size: 24rpx;
  color: #134585;
  margin-left: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e8e8e8;
}

/* 切换按钮区域 */
.tab-section {
  background: #ffffff;
  padding: 20rpx 30rpx;
  margin: 0 30rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tab-wrapper {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  position: relative;
  transition: all 0.3s ease;
  border-radius: 12rpx;
}

.tab-item.active {
  background: rgba(19, 69, 133, 0.08);
}

.tab-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #134585;
  font-weight: bold;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 60rpx;
  height: 4rpx;
  background: #134585;
  border-radius: 2rpx;
}

/* 内容区域 */
.content-area {
  flex: 1;
  padding: 0 30rpx;
  height: calc(100vh - 600rpx);
}

.content-panel {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.panel-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.panel-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #134585;
  margin-bottom: 16rpx;
}

.panel-subtitle {
  font-size: 26rpx;
  color: #888;
}

/* 卡片网格 */
.card-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.cert-card {
  width: 30%;
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.cert-card:active {
  border-color: #134585;
  transform: scale(0.98);
}

.cert-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
  font-size: 40rpx;
}

.cert-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.cert-desc {
  font-size: 22rpx;
  color: #888;
}

/* 区块标题 */
.section-block {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #134585;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #134585;
}

/* 剂型标签 */
.dosage-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.dosage-tag {
  background: linear-gradient(135deg, #134585, #1a5aa0);
  color: #ffffff;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

/* 产品类别网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-item {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 24rpx;
  flex: 1;
  min-width: 280rpx;
  border: 2rpx solid #e8e8e8;
}

.category-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #134585;
  background: rgba(19, 69, 133, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 功效标签 */
.function-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.function-tag {
  background: #f0f4f8;
  color: #134585;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: 2rpx solid rgba(19, 69, 133, 0.2);
}

/* 优势列表 */
.advantage-section {
  margin-bottom: 40rpx;
}

.advantage-list {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 24rpx;
}

.advantage-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
}

.advantage-item:last-child {
  border-bottom: none;
}

.advantage-dot {
  width: 12rpx;
  height: 12rpx;
  background: #134585;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.advantage-text {
  font-size: 28rpx;
  color: #555;
}

/* 核心模式卡片 */
.model-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.model-card {
  background: linear-gradient(135deg, #f8fafc, #ffffff);
  border-radius: 12rpx;
  padding: 30rpx;
  border-left: 6rpx solid #134585;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.model-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.model-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #134585;
  display: block;
  margin-bottom: 12rpx;
}

.model-desc {
  font-size: 26rpx;
  color: #666;
}

/* 资源卡片 */
.resource-cards {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.resource-card {
  flex: 1;
  background: linear-gradient(135deg, #134585, #1a5aa0);
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  text-align: center;
}

.resource-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.resource-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  display: block;
  margin-bottom: 8rpx;
}

.resource-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 货盘矩阵 */
.product-matrix {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.matrix-item {
  flex: 1;
  min-width: 280rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 30rpx;
  text-align: center;
  border: 2rpx solid #e8e8e8;
}

.matrix-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #134585;
  display: block;
  margin-bottom: 12rpx;
}

.matrix-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.matrix-channel {
  font-size: 22rpx;
  color: #888;
}

/* 产品列表 */
.product-list {
  background: #f8fafc;
  border-radius: 12rpx;
  overflow: hidden;
}

.product-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.product-item:last-child {
  border-bottom: none;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #888;
}

.product-arrow {
  font-size: 40rpx;
  color: #134585;
  font-weight: bold;
}

/* CTA按钮区域 */
.cta-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.cta-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
  border: none;
}

.cta-btn.primary {
  background: linear-gradient(135deg, #134585, #1a5aa0);
  color: #ffffff;
}

.cta-btn.secondary {
  background: #ffffff;
  color: #134585;
  border: 2rpx solid #134585;
}

.cta-btn::after {
  border: none;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-top: 1rpx solid #e8e8e8;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.nav-text {
  font-size: 22rpx;
  color: #999;
}

.nav-item.active .nav-text {
  color: #134585;
}

/* 滚动条样式优化 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}
